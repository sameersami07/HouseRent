{
  "version": 3,
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "api/index.js"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "client/assets/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "client/index.html"
    }
  ],
  "crons": []
}
